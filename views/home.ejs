<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Dashboard | PHARMABILL</title>
</head>
<body>
  <%- include('partials/_navbar.ejs')%>

  <div class="main-content" style="max-width: 1000px; width: 100%; margin: 0 auto; box-sizing: border-box;">
    
    <% if(user) { %>
      <div class="hero-section" style="background: white; padding: 2.5rem 2rem; border-radius: var(--radius-card); border: 1px solid var(--border); text-align: left; margin-bottom: 2.5rem; box-shadow: var(--shadow-sm);">
        <h1 style="margin-bottom: 0.25rem;">Pharmacy Billing Management</h1>
        <p style="color: var(--secondary); font-size: 1rem; margin: 0;">
          Welcome back, <strong><%= user.username.charAt(0).toUpperCase() + user.username.slice(1).toLowerCase() %></strong>. 
          Role: <span class="badge status-pending" style="margin-left: 0.25rem;"><%= user.role.toUpperCase() %></span>
        </p>
      </div>

      <div class="dashboard-grid">
        <a href="/patients/search" class="action-card">
          <span style="font-size: 2rem; margin-bottom: 0.5rem; display: block;">🔍</span>
          <h3>Patient Search</h3>
          <p style="color: var(--secondary); font-size: 0.875rem;">Find records and manage billing plans.</p>
        </a>

        <a href="/patients/new" class="action-card">
          <span style="font-size: 2rem; margin-bottom: 0.5rem; display: block;">👤</span>
          <h3>New Patient</h3>
          <p style="color: var(--secondary); font-size: 0.875rem;">Create profile for insurance verification.</p>
        </a>
      </div>

      <% if(user.role === 'admin') { %>
        <div style="margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--border);">
          <h2 style="margin-bottom: 1.5rem; font-size: 0.85rem; color: var(--secondary); text-transform: uppercase; letter-spacing: 0.05em;">🛡️ Administrator Tools</h2>
          <div class="admin-grid">
            <a href="/user" class="action-card">
              <span style="font-size: 2rem; margin-bottom: 0.5rem; display: block;">📋</span>
              <h3>Staff Directory</h3>
              <p style="color: var(--secondary); font-size: 0.875rem;">Manage user roles and permissions.</p>
            </a>
            <a href="/auth/sign-up" class="action-card">
              <span style="font-size: 2rem; margin-bottom: 0.5rem; display: block;">➕</span>
              <h3>Register Staff</h3>
              <p style="color: var(--secondary); font-size: 0.875rem;">Add new members to the system.</p>
            </a>
          </div>
        </div>
      <% } %>
    
    <% } else { %>
      <div class="hero-section" style="background: white; padding: 4rem 2rem; border-radius: var(--radius-card); border: 1px solid var(--border); text-align: center; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem;">
        
        <div style="background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; padding: 1rem 1.5rem; border-radius: 8px; width: 100%; max-width: 600px; text-align: left; margin-bottom: 1rem; font-size: 0.875rem; line-height: 1.5;">
          <strong>🎓 Academic Portfolio Notice:</strong> This website is a mock student sandbox application created strictly for educational web development testing. It is not an actual commercial medical utility, does not collect real patient information, and does not process real financial billing transactions. Do not enter sensitive corporate or personal data.
        </div>

        <h1 style="margin: 0; text-align: center;">Secure Billing Portal</h1>
        <p style="color: var(--secondary); max-width: 500px; margin: 0 auto 1.5rem auto; font-size: 1rem;">
          Please sign in to manage patient billing, verify insurance plans, and access sensitive clinical data.
        </p>
        <a href="/auth/sign-in" class="btn btn-primary" style="padding: 0.75rem 2.5rem;">Sign In to Dashboard</a>
        <p style="margin-top: 1rem; font-size: 0.8125rem; color: var(--secondary); margin-bottom: 0;">
          New staff? Contact your administrator for system access.
        </p>
      </div>
    <% } %>
  </div>
  
  <%- include('partials/_footer.ejs') %>
  
</body>
</html>
