<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>System Error | PHARMABILL</title>
</head>
<body>
  <%- include('./partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="form-container" style="max-width: 500px; text-align: center;">
      
      <div class="error-icon" style="font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
      <h1 style="color: var(--danger);">System Alert</h1>
      
      <div class="error-msg" style="text-align: left; margin: 1.5rem 0; background: #fff5f5; border-color: #feb2b2;">
        <strong style="display: block; margin-bottom: 5px; text-transform: uppercase; font-size: 0.75rem; color: var(--danger);">Error Details:</strong>
        <p style="margin: 0; line-height: 1.4;"><%= typeof err !== 'undefined' ? err : 'An unknown error occurred!' %></p>
      </div>

      <div class="form-actions" style="display: flex; flex-direction: column; gap: 10px; margin-top: 2rem;">
        <button class="btn btn-primary btn-block" onClick="window.history.back()">
          ← Return to Previous Page
        </button>
        <a href="/" class="btn btn-outline btn-block">
          Go to Home Dashboard
        </a>
      </div>
      
    </div>
  </div>
</body>
</html>
