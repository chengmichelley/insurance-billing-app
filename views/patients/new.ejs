<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Add Patient | Billing System</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="form-container" style="max-width: 450px;">
      <h1>Add a New Patient</h1>
      <p style="color: var(--secondary); margin-bottom: 2rem; text-align: center;">Enter patient details to begin insurance verification.</p>

      <form action="/patients/" method="POST">
        
        <div class="form-group">
          <label for="firstName">First Name</label>
          <input type="text" id="firstName" name="firstName" placeholder="e.g. John" required autofocus/>
        </div>

        <div class="form-group">
          <label for="lastName">Last Name</label>
          <input type="text" id="lastName" name="lastName" placeholder="e.g. Doe" required/>
        </div>

        <div class="form-group">
          <label for="dob">Date of Birth</label>
          <input type="tel" id="dob" name="dob" placeholder="MM/DD/YYYY" maxlength="10" oninput="formatDate(this)" required/>
        </div>

        <div class="form-actions" style="display: flex; flex-direction: column; gap: 10px; margin-top: 2rem;">
          <button type="submit" class="btn btn-primary btn-block">Create Patient Profile</button>
          <a href="/patients/search" class="btn btn-outline btn-block">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <script>
    let lastValue = '';
    function formatDate(input) {
      let v = input.value.replace(/\D/g, '');
      if(input.value.length < lastValue.length) {
        lastValue = input.value;
        return;
      }
      let finalValue = '';
      if(v.length > 0) {
        finalValue = v.slice(0, 2); 
        if(v.length > 2) {
          finalValue += '/' + v.slice(2,4);
          if(v.length > 4) {
            finalValue += '/' + v.slice(4, 8);
          }
        }
      }
      input.value = finalValue;
      lastValue = finalValue;
    }
  </script>
</body>
</html>
