<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Add Patient | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="form-container">
      <h1>Add a New Patient</h1>
      <p style="color: var(--secondary); margin-top: -1rem; margin-bottom: 2rem; font-size: 0.875rem;">Enter patient details to begin insurance verification.</p>

      <form action="/patients/" method="POST">
        
        <div class="form-group">
          <label for="firstName">First Name</label>
          <input type="text" id="firstName" name="firstName" placeholder="e.g. John" required autofocus/>
        </div>

        <div class="form-group">
          <label for="lastName">Last Name</label>
          <input type="text" id="lastName" name="lastName" placeholder="e.g. Doe" required/>
        </div>

        <div class="form-group">
          <label for="dob">Date of Birth</label>
          <input type="tel" id="dob" name="dob" placeholder="MM/DD/YYYY" maxlength="10" required/>
        </div>

        <div class="form-actions" style="display: flex; gap: 1rem; margin-top: 2rem;">
          <button type="submit" class="btn btn-primary" style="flex: 1;">Create Patient Profile</button>
          <a href="/patients/search" class="btn btn-outline" style="flex: 1;">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <%- include('partials/_footer.ejs') %>

</body>
</html>
