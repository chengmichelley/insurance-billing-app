<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Patient Profile | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content" style="max-width: 1100px; width: 100%; margin: 0 auto; padding: 0 1rem; box-sizing: border-box;">
    
    <div class="profile-card" style="width: 100%; max-width: 1100px; box-sizing: border-box; background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); overflow: hidden; margin-bottom: 2rem;">
      
      <div class="profile-header" style="background: var(--text-dark); color: white; padding: 2rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
          <h1 style="margin: 0; color: white;"><%= patient.firstName %> <%= patient.lastName %></h1>
          <p style="margin: 5px 0 0 0; color: #94a3b8; font-size: 0.9rem;">Patient ID: <%= patient._id.toString().slice(-6).toUpperCase() %></p>
        </div>
        <div class="badge <%= patient.isInactivated ? 'status-denied' : 'status-paid' %>" style="font-size: 0.9rem; padding: 8px 16px;">
          <%= patient.isInactivated ? '❌ INACTIVE' : '✅ ACTIVE' %>
        </div>
      </div>

      <div class="profile-body" style="padding: 2.5rem; display: flex; flex-direction: column; gap: 3rem;">
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); align-items: stretch; border-bottom: 1px solid var(--border); padding-bottom: 2.5rem; width: 100%; box-sizing: border-box;">
          
          <div style="box-sizing: border-box; display: flex; flex-direction: column; justify-content: space-between; padding-right: 2rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
              <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--secondary); margin: 0; letter-spacing: 0.5px;">
                Demographic Details
              </h3>
              <div style="display: flex; gap: 0.5rem; align-items: center;">
                <a href="/patients/<%= patient._id %>/edit" class="btn btn-outline" style="padding: 4px 10px; font-size: 0.8rem;">
                  ✏️ Edit
                </a>
                <form action="/patients/<%= patient._id %>/inactivate?_method=PUT" method="POST" style="margin: 0; display: inline-block;">
                  <button type="submit" class="btn btn-outline <%= patient.isInactivated ? 'btn-status-activate' : 'btn-status-inactivate' %>" style="padding: 4px 10px; font-size: 0.8rem; background: transparent;">
                    <%= patient.isInactivated ? '✨ Activate' : '🚫 Inactivate' %>
                  </button>
                </form>
              </div>
            </div>
            
            <div class="info-grid" style="box-shadow: none; border: none; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; width: 100%; max-width: 100%;">
              <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
                <label style="margin: 0;">First Name</label>
                <span style="font-size: 1.1rem; font-weight: 600;"><%= patient.firstName %></span>
              </div>
              <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
                <label style="margin: 0;">Last Name</label>
                <span style="font-size: 1.1rem; font-weight: 600;"><%= patient.lastName %></span>
              </div>
              <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; padding-bottom: 0.5rem;">
                <label style="margin: 0;">Date of Birth</label>
                <span style="font-size: 1.1rem; font-weight: 600;"><%= patient.dob %></span>
              </div>
            </div>
          </div>

          <div style="box-sizing: border-box; width: 100%; display: flex; flex-direction: column; border-left: 1px solid var(--border); padding-left: 2rem;">
            <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--secondary); margin-bottom: 1.5rem; letter-spacing: 0.5px;">
              Current Coverage Summary
            </h3>
            <div class="record-card" style="margin: auto 0; border-left: 4px solid var(--primary); padding: 1.5rem; background: #f8fafc; box-sizing: border-box; width: 100%; max-width: 100%;">
              <% if (locals.primaryInsurance) { %>
                <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                  <div>
                    <strong style="display: block; font-size: 1.1rem; color: var(--primary);">
                      <%= primaryInsurance.insurance.providerName %>
                    </strong>
                    <span style="font-size: 0.85rem; color: var(--secondary); display: block; margin-top: 6px;">
                      ID: <%= primaryInsurance.insurance.memberId %>
                    </span>
                    <span style="font-size: 0.85rem; color: var(--secondary); display: block;">
                      BIN: <%= primaryInsurance.insurance.bin %>
                    </span>
                  </div>
                  <span class="badge status-paid" style="font-size: 0.75rem;">Primary</span>
                </div>
              <% } else { %>
                <p style="margin: 0; font-size: 0.9rem; color: var(--secondary); font-style: italic; text-align: center; padding: 1.5rem 0; width: 100%;">
                  No active insurance plans found for this patient.
                </p>
              <% } %>
            </div>
          </div>

        </div>

        <div style="width: 100%; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto;">
          <h3 style="font-size: 0.85rem; text-transform: uppercase; color: var(--secondary); margin-bottom: 1.5rem; letter-spacing: 0.5px; text-align: center; width: 100%;">
            Clinical Billing Actions
          </h3>
          
          <div style="display: flex; flex-direction: row; justify-content: center; align-items: center; gap: 1.5rem; width: 100%; max-width: 888px; margin: 0 auto; padding: 0; box-sizing: border-box; flex-wrap: wrap;">
            
            <a href="/patients/<%= patient._id %>/billing" class="action-card" style="width: 280px; min-width: 280px; max-width: 280px; box-sizing: border-box; margin: 0;">
              <span style="font-size: 1.5rem; margin-bottom: 6px; display: block;">📋</span>
              <strong>View All Insurance</strong>
              <p style="font-size: 0.8rem; color: var(--secondary); margin: 4px 0 0 0; line-height: 1.3;">Manage plans & verify codes</p>
            </a>

            <a href="/patients/<%= patient._id %>/billing/recommendation" class="action-card" style="width: 280px; min-width: 280px; max-width: 280px; box-sizing: border-box; margin: 0; border-color: var(--primary);">
              <span style="font-size: 1.5rem; margin-bottom: 6px; display: block;">★</span>
              <strong style="color: var(--primary);">Optimize Billing Rank</strong>
              <p style="font-size: 0.8rem; color: var(--secondary); margin: 4px 0 0 0; line-height: 1.3;">Analyze logic order & scores</p>
            </a>
            
            <a href="/patients/<%= patient._id %>/billing/new" class="action-card" style="width: 280px; min-width: 280px; max-width: 280px; box-sizing: border-box; margin: 0;">
              <span style="font-size: 1.5rem; margin-bottom: 6px; display: block;">➕</span>
              <strong>Add New Plan</strong>
              <p style="font-size: 0.8rem; color: var(--secondary); margin: 4px 0 0 0; line-height: 1.3;">Add secondary or medicare</p>
            </a>

          </div>
        </div>

      </div>
    </div>

    <a href="/patients/search" style="color: var(--secondary); text-decoration: none; font-size: 0.9rem; margin-left: 4px; margin-top: 1rem; display: inline-block;">← Back to Search</a>
  </div>

  <%- include('partials/_footer.ejs') %>

</body>
</html>
