<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search for a Patient</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>
  <h1>Search for a Patient</h1>
  <form action ='/patients/search' method="GET">
    <label for="firstName">First Name:</label>
    <input type="text" id="firstName" name="firstName" autofocus placeholder="First Name" value="<%= typeof firstName !== 'undefined' ? firstName : '' %>"/>

    <label for="lastName">Last Name:</label>
    <input type="text" id="lastName" name="lastName" placeholder="Last Name" value="<%= typeof lastName !== 'undefined' ? lastName : '' %>"/>

    <label for="dob">Date of Birth:</label>
    <input type="tel" id="dob" name="dob" maxlength="10" placeholder="MM/DD/YYYY" oninput="formatDate(this)" value="<%= typeof dob !== 'undefined' ? dob: '' %>" required/>

    <button type="submit">Find Patient</button>
  </form>

  <% if(typeof message !== 'undefined' && message) { %>
    <%= message %>
  <% } %>

  <% if(err) { %>
    <p><%= err %></p>
  <% } %>

  <% if (results && results.length > 0) { %>
  <h2>Matching Patients:</h2>
  <ul>
    <% results.forEach(patient => { %>
      <li>
        <strong><%= patient.firstName %> <%= patient.lastName %></strong><br>
        (DOB: <%= patient.dob %>)
        <br>
        <a href="/patients/<%= patient._id %>">View Profile</a>
        <a href="/patients/select/<%= patient._id %>">Create a New Bill</a>
      </li>
    <% }) %>
  </ul>
  <% } %>
<% if (results && results.length === 0 && (typeof firstName !== 'undefined' || typeof dob !== 'undefined')) { %>
  <hr>
  <p>No patients found. <a href="/patients/new">Add a New Patient!</a></p>
<% } %>
  <script>
    let lastValue = '<%= typeof dob !== "undefined" ? dob: "" %>';

    function formatDate(input) {
      let v = input.value.replace(/\D/g, '');

      if(input.value.length < lastValue.length) {
        lastValue = input.value;
        return;
      }

      let finalValue = '';
      if(v.length > 0) {
        finalValue = v.slice(0, 2); 
        if(v.length > 2) {
          finalValue += '/' + v.slice(2,4);
          if(v.length > 4) {
            finalValue += '/' + v.slice(4, 8);
          }
        }
      }
      input.value = finalValue;
      lastValue = finalValue;
    }
  </script>
</body>
</html>