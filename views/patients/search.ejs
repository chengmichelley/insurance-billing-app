<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Patient Search | PHARMABILL</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>
    <div class="main-content">

        <% if (typeof results !== 'undefined' && results.length > 1) { %>
            <div class="wide-wrapper" style="margin-top: 1rem;">
                <h1>Find a Patient</h1>
                <h2 style="margin-bottom: 2rem; color: var(--secondary); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    Multiple Matches Found (<%= results.length %>)
                </h2>
                <div class="record-list">
                    <% results.forEach(p => { %>
                        <div class="record-card" style="padding: 1.25rem 1.5rem;">
                            <div class="p-info">
                                <strong style="font-size: 1.1rem; color: var(--primary); display: block;">
                                    <%= p.firstName %> <%= p.lastName %>
                                </strong>
                                <p style="margin: 6px 0 0 0; color: var(--secondary); font-size: 0.875rem; display: flex; align-items: center; flex-wrap: wrap;">
                                    <strong>DOB:</strong> <span style="color: var(--text-dark); margin-left: 0.25rem;"><%= p.dob %></span>
                                    <span style="margin: 0 0.75rem; color: var(--border);">|</span>
                                    <strong style="margin-right: 0.375rem;">Status:</strong>
                                    <span class="badge <%= p.isInactivated ? 'status-denied' : 'status-paid' %>">
                                        <%= p.isInactivated ? 'INACTIVE' : 'ACTIVE' %>
                                    </span>
                                </p>
                            </div>
                            <div style="display: flex; gap: 0.75rem;">
                                <a href="/patients/<%= p._id %>" class="btn btn-outline">View Profile</a>
                                <a href="/patients/<%= p._id %>/billing/new" class="btn btn-primary">+ Add Insurance</a>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
                    <a href="/patients/search" class="btn btn-outline">← Back to Search</a>
                </div>
            </div>

        <% } else if (typeof results !== 'undefined' && results.length === 0 && (firstName || lastName || dob)) { %>
            <div class="form-container" style="text-align: center;">
                <h1>No Patient Found</h1>
                <div class="error-msg" style="margin: 2rem 0;">
                    No matches found matching those search details. Check the spelling or create a new profile.
                </div>
                <div class="form-actions" style="display: flex; gap: 1rem;">
                    <a href="/patients/search" class="btn btn-primary" style="flex: 1;">← Search Again</a>
                    <a href="/patients/new" class="btn btn-outline" style="flex: 1;">Create New Patient</a>
                </div>
            </div>

        <% } else { %>
            <div class="form-container">
                <h1>Find a Patient</h1>
                <p style="color: var(--secondary); margin-top: -1rem; margin-bottom: 2rem; font-size: 0.875rem;">
                    Search by name or date of birth to manage billing.
                </p>
                <% if(typeof message !== 'undefined' && message) { %>
                    <div class="badge status-pending" style="width: 100%; padding: 0.75rem 1rem; margin-bottom: 1.5rem; border-radius: var(--radius-button);">
                        <%= message %>
                    </div>
                <% } %>
                <% if(typeof err !== 'undefined' && err) { %>
                    <div class="error-msg" style="margin-bottom: 1.5rem;">
                        <%= err %>
                    </div>
                <% } %>
                <form action='/patients/search' method="GET">
                    <div class="form-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" name="firstName" autofocus placeholder="First name" value="<%= typeof firstName !== 'undefined' ? firstName : '' %>"/>
                    </div>
                    <div class="form-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" name="lastName" placeholder="Last name" value="<%= typeof lastName !== 'undefined' ? lastName : '' %>"/>
                    </div>
                    <div class="form-group">
                        <label for="dob">Date of Birth</label>
                        <input type="tel" id="dob" name="dob" maxlength="10" placeholder="MM/DD/YYYY" data-initial-value="<%= typeof dob !== 'undefined' ? dob : '' %>" value="<%= typeof dob !== 'undefined' ? dob: '' %>" required/>
                    </div>
                    <div class="form-actions" style="display: flex; gap: 1rem; margin-top: 2rem;">
                        <button type="submit" class="btn btn-primary" style="flex: 1;">Find Patient Profile</button>
                        <a href="/patients/new" class="btn btn-outline" style="flex: 1;">Create Patient</a>
                    </div>
                </form>
            </div>
        <% } %>

    </div>

    <script src="/javascripts/dob-formatter.js" defer></script>
</body>
</html>
