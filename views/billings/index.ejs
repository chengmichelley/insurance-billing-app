<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Insurance Plans | PHARMABILL</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="main-content">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h1 style="margin-bottom: 0;">Insurance Plans for <%= activePatient.firstName %> <%= activePatient.lastName %></h1>
        <a href="/patients/<%= activePatient._id %>/billing/new" class="btn btn-primary">
          + Add New Insurance Plan
        </a>
      </div>

      <div class="record-list">
        <% if( insurance && insurance.length > 0) { %>
          <% insurance.forEach(item => { %>
            <div class="record-card" style="padding: 1.5rem;">
              <a href="/patients/<%= activePatient._id %>/billing/<%= item._id %>" style="text-decoration: none; display: block; width: 100%;">
                
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                  <span class="record-title" style="font-size: 1.1rem; font-weight: 600; color: var(--primary);">
                    <%= item.providerName || 'Unknown Provider' %>
                  </span>
                  
                  <div style="display: flex; gap: 5px;">
                    <% if(item.isInactivated) { %> 
                      <span class="badge status-denied">Inactive</span> 
                    <% } else { %>
                      <span class="badge <%= item.label === 'Primary' ? 'status-paid' : 'status-pending' %>">
                        <%= item.label %>
                      </span>
                    <% } %>
                  </div>
                </div>

                <div class="record-meta" style="font-size: 0.875rem; color: var(--secondary);">
                  <strong style="color: var(--text-dark);">ID:</strong> <%= item.memberId %> <span style="color: var(--border); margin: 0 0.5rem;">|</span> 
                  <strong style="color: var(--text-dark);">Type:</strong> <%= item.coverageType.toUpperCase() %> 
                  <% if(item.state) { %> <span style="color: var(--border); margin: 0 0.5rem;">|</span> <strong style="color: var(--text-dark);">State:</strong> <%= item.state %><% } %>
                </div>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-card); text-align: center; padding: 4rem 2rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.25rem;">
            <p style="color: var(--secondary); margin: 0; font-size: 0.95rem;">No insurance records found for this patient.</p>
            <a href="/patients/<%= activePatient._id %>/billing/new" class="btn btn-outline">Add First Plan</a>
          </div>
        <% } %>  
      </div>

      <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; gap: 1rem;">
        <a href="/patients/<%= activePatient._id %>" class="btn btn-outline">Back to Profile</a>
        <a href="/patients/search" class="btn btn-outline">Search Another Patient</a>
      </div>
    </div>

    <%- include('../partials/_footer.ejs') %>

</body>
</html>
