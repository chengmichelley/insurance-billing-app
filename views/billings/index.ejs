<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Insurance Plans | PHARMABILL</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="main-content">
      <h1>Insurance Plans for <%= activePatient.firstName %> <%= activePatient.lastName %></h1>
      
      <div class="header-actions" style="margin-bottom: 2rem; display: flex; gap: 1rem;">
        <a href="/patients/<%= activePatient._id %>/billing/new" class="btn btn-primary">
          + Add New Insurance Plan
        </a>
      </div>

      <div class="record-list">
        <% if( insurance && insurance.length > 0) { %>
          <% insurance.forEach(item => { %>
            <div class="record-card" style="margin-bottom: 1rem; position: relative;">
              <a href="/patients/<%= activePatient._id %>/billing/<%= item.insurance._id %>" style="text-decoration: none; display: block;">
                
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                  <span class="record-title" style="font-size: 1.2rem; font-weight: 700; color: var(--primary);">
                    <%= item.insurance.providerName || 'Unknown Provider' %>
                  </span>
                  
                  <div style="display: flex; gap: 5px;">
                    <% if(item.insurance.isInactivated) { %> 
                      <span class="badge status-denied">Inactive</span> 
                    <% } else { %>
                      <span class="badge <%= item.label === 'Primary' ? 'status-paid' : 'status-pending' %>">
                        <%= item.label %>
                      </span>
                    <% } %>
                  </div>
                </div>

                <div class="record-meta">
                  <strong>ID:</strong> <%= item.insurance.memberId %> | 
                  <strong>Type:</strong> <%= item.insurance.coverageType.toUpperCase() %> 
                  <% if(item.insurance.state) { %> | <strong>State:</strong> <%= item.insurance.state %><% } %>
                </div>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <div class="form-container" style="text-align: center; padding: 3rem;">
            <p>No insurance records found for this patient.</p>
            <a href="/patients/<%= activePatient._id %>/billing/new" class="btn btn-outline">Add First Plan</a>
          </div>
        <% } %>  
      </div>

      <div style="margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border);">
        <a href="/patients/<%= activePatient._id %>" class="btn btn-outline">Back to Profile</a>
        <a href="/patients/search" class="btn btn-outline">Search Another Patient</a>
      </div>
    </div>
</body>
</html>
