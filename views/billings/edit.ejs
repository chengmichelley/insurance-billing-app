<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Edit Billing | <%= billing.providerName %></title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="form-container">
      <h1>Edit Billing: <%= billing.providerName %></h1>

      <form action="/patients/<%= billing.patient %>/billing/<%= billing._id%>?_method=PUT" method="POST">

        <div class="form-group">
          <label for="providerName">Provider Name</label>
          <input type="text" id="providerName" name="providerName" value="<%= billing.providerName %>"/>
        </div>

        <div class="form-group">
          <label for="memberId">Member ID</label>
          <input type="text" id="memberId" name="memberId" value="<%= billing.memberId %>"/>
        </div>

        <div class="form-row">
          <div class="form-group" style="flex: 1;">
            <label for="bin">BIN</label>
            <input type="text" id="bin" name="bin" value="<%= billing.bin %>" required/>
          </div>
          <div class="form-group" style="flex: 1;">
            <label for="pcn">PCN</label>
            <input type="text" id="pcn" name="pcn" value="<%= billing.pcn %>" required/>
          </div>
        </div>

        <div class="form-group">
          <label for="group">Group</label>
          <input type="text" id="group" name="group" value="<%= billing.group %>"/>
        </div>

        <div class="form-group">
          <label for="coverageType">Coverage Type</label>
          <select name="coverageType" required>
            <option value="primary" <%= billing.coverageType === 'primary' ? 'selected' : '' %>>Primary</option>
            <option value="secondary" <%= billing.coverageType === 'secondary' ? 'selected' : '' %>>Secondary</option>
            <option value="medicaid" <%= billing.coverageType === 'medicaid' ? 'selected' : '' %>>Medicaid</option>
            <option value="medicare" <%= billing.coverageType === 'medicare' ? 'selected' : '' %>>Medicare</option>
            <option value="commercial" <%= billing.coverageType === 'commercial' ? 'selected' : '' %>>Commercial</option>
          </select>
        </div>

        <div class="form-group">
          <label for="priority">Priority (0-100)</label>
          <input type="number" id="priority" name="priority" value="<%= billing.priority %>" min="0" max="100"/>
        </div>

        <div class="checkbox-group">
          <input type="checkbox" id="isInactivated" name="isInactivated" value="true" <%= billing.isInactivated ? 'checked' : '' %>/>
          <label for="isInactivated" style="margin-bottom: 0;">Inactivate this record</label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Update Billing</button>
          <a href="/patients/<%= billing.patient %>/billing/<%= billing._id %>" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
</body>
</html>
