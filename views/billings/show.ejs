<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Insurance Plan Details | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="form-container">
      
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem; width: 100%;">
        <div>
          <h1 style="margin: 0; font-size: 1.5rem; color: var(--primary);"><%= insurance.providerName %></h1>
          <p style="margin: 4px 0 0 0; color: var(--secondary); font-size: 0.875rem;">
            Patient: <%= activePatient.firstName %> <%= activePatient.lastName %>
          </p>
        </div>
        <span class="badge <%= insurance.isInactivated ? 'status-denied' : 'status-paid' %>">
          <%= insurance.isInactivated ? '❌ INACTIVE' : '✅ ACTIVE' %>
        </span>
      </div>

      <div class="info-grid" style="display: flex; flex-direction: column; gap: 1.25rem; width: 100%;">
        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">Member ID</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.memberId %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">BIN</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.bin %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">PCN</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.pcn %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">Group</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.group || 'N/A' %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">Plan State</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.state || 'National' %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">Coverage Type</label>
          <span class="badge" style="background: #e0f2fe; color: #0369a1; text-transform: uppercase;"><%= insurance.coverageType %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border); padding-bottom: 0.5rem;">
          <label style="margin: 0;">Relationship</label>
          <span style="font-size: 1rem; font-weight: 500; text-transform: capitalize;"><%= insurance.relationship %></span>
        </div>

        <div class="info-item" style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; padding-bottom: 0.5rem;">
          <label style="margin: 0;">Manual Boost</label>
          <span style="font-size: 1rem; font-weight: 500;"><%= insurance.priority %></span>
        </div>
      </div>

      <div class="form-actions" style="display: flex; gap: 1rem; margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem; width: 100%;">
        <a href="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/edit" class="btn btn-primary" style="flex: 1; text-align: center;">
          Edit Record
        </a>

        <form action="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/inactivate?_method=PUT" method="POST" style="margin: 0; flex: 1;">
          <button type="submit" class="btn btn-outline <%= insurance.isInactivated ? 'btn-status-activate' : 'btn-status-inactivate' %>" style="width: 100%; background: transparent;">
            <%= insurance.isInactivated ? '✨ Activate Plan' : '🚫 Inactivate Plan' %>
          </button>
        </form>
      </div>

      <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; font-size: 0.875rem; width: 100%;">
        <a href="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/confirm_delete" style="color: var(--danger); text-decoration: none;">
          Delete Record
        </a>
        <a href="/patients/<%= activePatient._id %>/billing" style="color: var(--secondary); text-decoration: none;">
          Go Back to List
        </a>
      </div>

    </div>
  </div>

  <%- include('../partials/_footer.ejs') %>

</body>
</html>
