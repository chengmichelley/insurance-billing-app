<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Insurance Plan Details | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="detail-header">
      <h1><%= insurance.providerName || 'Insurance' %> Details</h1>
      <p style="color: var(--secondary);">
        Patient: <strong><%= activePatient.firstName %> <%= activePatient.lastName %></strong>
      </p>
    </div>

    <div class="info-grid">
      <div class="info-item">
        <label>Provider Name</label>
        <span><%= insurance.providerName %></span>
      </div>
      <div class="info-item">
        <label>Member ID</label>
        <span><%= insurance.memberId %></span>
      </div>
      <div class="info-item">
        <label>BIN</label>
        <span><%= insurance.bin %></span>
      </div>
      <div class="info-item">
        <label>PCN</label>
        <span><%= insurance.pcn %></span>
      </div>
      <div class="info-item">
        <label>Group</label>
        <span><%= insurance.group || 'N/A' %></span>
      </div>
      <div class="info-item">
        <label>Plan State</label>
        <span><%= insurance.state || 'National' %></span>
      </div>
      <div class="info-item">
        <label>Coverage Type</label>
        <span class="badge" style="background: #e0f2fe; color: #0369a1; text-transform: uppercase;"><%= insurance.coverageType %></span>
      </div>
      <div class="info-item">
        <label>Relationship</label>
        <span style="text-transform: capitalize;"><%= insurance.relationship %></span>
      </div>
      <div class="info-item">
        <label>Manual Boost</label>
        <span><%= insurance.priority %></span>
      </div>
      <div class="info-item">
        <label>Status</label>
        <span class="badge <%= insurance.isInactivated ? 'status-denied' : 'status-paid' %>">
          <%= insurance.isInactivated ? 'INACTIVE' : 'ACTIVE' %>
        </span>
      </div>
    </div>

    <div class="action-bar" style="margin-top: 2rem; display: flex; gap: 1rem; align-items: center;">
      <a href="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/edit" class="btn btn-primary">
        Edit Record
      </a>

      <form action="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/inactivate?_method=PUT" method="POST" style="margin: 0;">
        <button type="submit" class="btn btn-outline" style="border-color: var(--warning); color: var(--warning);" <%= insurance.isInactivated ? 'disabled' : '' %>>
          <%= insurance.isInactivated ? 'Plan is Inactive' : 'Inactivate Plan' %>
        </button>
      </form>
    </div>

    <div style="margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border);">
      <a href="/patients/<%= activePatient._id %>/billing/<%= insurance._id %>/confirm_delete" style="color: var(--danger); text-decoration: none; font-size: 0.9rem;">
        Delete This Insurance Record
      </a>
      <span style="color: var(--border); margin: 0 10px;">|</span>
      <a href="/patients/<%= activePatient._id %>/billing" style="color: var(--secondary); text-decoration: none; font-size: 0.9rem;">
        Go Back to List
      </a>
    </div>
  </div>
</body>
</html>
