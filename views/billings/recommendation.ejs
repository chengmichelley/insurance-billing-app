<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Billing Recommendation | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content" style="max-width: 800px; margin: 0 auto;">
    
    <div style="margin-bottom: 2.5rem; text-align: center;">
      <h1>Insurance Recommendation</h1>
      <p style="color: var(--secondary);">Optimal billing order based on relationship and coverage type.</p>
    </div>

    <% if(results && results.length > 0) { %>
      <div class="record-list">
        <% results.forEach((r, index) => { %>
          <div class="record-card <%= index === 0 ? 'winner-card' : '' %>" style="margin-bottom: 1.5rem; padding: 2rem;">
            
            <% if (index === 0) { %>
              <span class="badge status-paid" style="margin-bottom: 1rem; display: inline-block;">★ RECOMMENDED PRIMARY ★</span>
            <% } %>

            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div>
                <h3 style="margin: 0; font-size: 1.4rem;"><%= r.insurance.providerName %></h3>
                <p style="color: var(--secondary); margin: 5px 0 1rem 0;">
                  Plan Label: <strong><%= r.label %></strong>
                </p>
              </div>
              <div class="badge status-pending" style="font-size: 0.9rem;">
                Rank Score: <%= r.score %>
              </div>
            </div>

            <div style="background: var(--bg-main); padding: 1rem; border-left: 4px solid var(--primary); border-radius: 4px; margin-top: 1rem;">
              <strong style="font-size: 0.75rem; text-transform: uppercase; color: var(--secondary); display: block; margin-bottom: 5px;">Billing Logic</strong>
              <p style="margin: 0; font-size: 0.9rem;">
                This plan is ranked as <strong><%= r.label %></strong> because it is a 
                <strong><%= r.insurance.coverageType %></strong> plan held by the 
                <strong><%= r.insurance.relationship %></strong>.
              </p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="form-container" style="text-align: center; padding: 4rem;">
        <p>No active insurance records found to rank.</p>
      </div>
    <% } %>

    <div style="margin-top: 2rem;">
      <a href="/patients/<%= activePatient._id %>/billing" class="btn btn-outline">
        ← Back to Billing List
      </a>
    </div>
  </div>
</body>
</html>