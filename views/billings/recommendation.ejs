<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Billing Recommendation | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content" style="max-width: 800px; width: 100%; margin: 0 auto; box-sizing: border-box;">
    
    <div style="margin-bottom: 2.5rem; text-align: left;">
      <h1 style="margin-bottom: 0.5rem;">Insurance Recommendation</h1>
      <p style="color: var(--secondary); font-size: 0.875rem;">Optimal billing order based on relationship and coverage type.</p>
    </div>

    <% if(results && results.length > 0) { %>
      <div class="record-list" style="gap: 1.5rem;">
        <% results.forEach((r, index) => { %>
          <div class="record-card <%= index === 0 ? 'winner-card' : '' %>" style="padding: 2rem; display: flex; flex-direction: column; align-items: stretch; justify-content: start;">
            
            <% if (index === 0) { %>
              <div style="margin-bottom: 1rem;">
                <span class="badge status-paid">★ RECOMMENDED PRIMARY ★</span>
              </div>
            <% } %>

            <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
              <div>
                <h3 style="margin: 0; font-size: 1.25rem;"><%= r.providerName %></h3>
                <p style="color: var(--secondary); margin: 0.25rem 0 0 0; font-size: 0.875rem;">
                  Plan Label: <strong><%= r.label %></strong>
                </p>
              </div>
              <span class="badge status-pending" style="font-size: 0.75rem;">
                Rank Score: <%= r.score %>
              </span>
            </div>

            <div style="background: var(--bg-main); padding: 1.25rem; border-left: 4px solid var(--primary); border-radius: var(--radius-button); margin-top: 1.5rem; width: 100%; box-sizing: border-box;">
              <label style="color: var(--secondary); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.375rem;">Billing Logic</label>
              <p style="margin: 0; font-size: 0.875rem; color: #334155; line-height: 1.5;">
                This plan is ranked as <strong><%= r.label %></strong> because it is a 
                <strong style="text-transform: capitalize;"><%= r.coverageType %></strong> plan held by the 
                <strong style="text-transform: capitalize;"><%= r.relationship %></strong>.
              </p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-card); text-align: center; padding: 4rem 2rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <p style="color: var(--secondary); margin: 0; font-size: 0.95rem;">No active insurance records found to rank.</p>
      </div>
    <% } %>

    <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
      <a href="/patients/<%= activePatient._id %>/billing" class="btn btn-outline">
        ← Back to Billing List
      </a>
    </div>
  </div>

  <%- include('../partials/_footer.ejs') %>

</body>
</html>
