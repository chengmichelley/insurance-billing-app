<nav>
  <div class="nav-left">
    <a href="/">
      <span>💊</span>
      <span>PHARMA<span style="color: #60a5fa;">BILL</span></span>
    </a>
    <a href="/patients/search">Patient Search</a>

    <% if(user && user.role === 'admin') { %>
      <a href="/user">Staff Directory</a>
    <% } %>
  </div>

  <div class="nav-center">
    <% if(user && typeof activePatient !== 'undefined' && activePatient) { %>
      <div class="active-content">
        <a href="/patients/<%= activePatient._id %>" style="color: inherit; font-weight: inherit; font-size: inherit;">
          Active: <strong><%= activePatient.firstName %> <%= activePatient.lastName %></strong>
          <span style="opacity: 0.8; font-size: 0.75rem; margin-left: 0.25rem;">(<%= activePatient.dob %>)</span>
        </a>
        <span style="color: rgba(255, 255, 255, 0.3); margin: 0 0.5rem;">|</span>
        <a href="/patients/clear-selection" style="color: #cbd5e1; font-size: 0.75rem; text-decoration: underline;">Switch</a>
      </div>
    <% } %>
  </div>

  <div class="nav-right">
    <% if(user) { %>
      <a href="/user/profile" style="border-right: 1px solid rgba(255, 255, 255, 0.15); padding-right: 0.75rem; margin-right: 0.75rem;">
        User: <strong><%= user.username.charAt(0).toUpperCase() + user.username.slice(1).toLowerCase() %></strong>
      </a>
      <a href="/auth/sign-out" style="color: #f87171;">Logout</a>
    <% } else { %>
      <a href="/auth/sign-in">Sign-In</a>
    <% } %>
  </div>
</nav>
