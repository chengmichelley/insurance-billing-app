<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Billing</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>
    <h1>All Billing Insurances</h1>
    <ul>
      <% billing.forEach(billing=> { %>
        <a href="/billing/<% billing._id%>">
          <%= billing.name %>
        </a>
      <% }) %>
    </ul>
</body>
</html>