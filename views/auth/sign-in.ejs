<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In</title>
  </head>
  <body>
    <%- include('../partials/_navbar.ejs') %>
    <h1>Sign In</h1>
    <% if(err) { %>
      <p style="color:red;font-style:italic;"><%= err %></p>
    <% } %>
    <form action="/auth/sign-in" method="POST">
      <div>
        <label for="username">Username:</label>
        <input type="text" id="username" name="username" required autofocus placeholder="Username"/>
      </div>
      <div>
        <label for="password">Password:</label>
        <input type="password" id="password" name="password" required placeholder="Enter a password"/>
      </div>
      <button type="submit">Sign In</button>
      <p>Don't have an account? <a href="/auth/sign-up">Sign up here</a></p>
    </form>
  </body>
</html>