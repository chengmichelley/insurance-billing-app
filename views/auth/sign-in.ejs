<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <title>Sign In | PHARMABILL</title>
</head>
<body>
  <%- include('../partials/_navbar.ejs') %>

  <div class="main-content">
    <div class="form-container">
      
      <div style="background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; padding: 0.875rem 1.25rem; border-radius: 8px; width: 100%; margin-bottom: 1.5rem; font-size: 0.8125rem; line-height: 1.4; text-align: left;">
        <strong>🎓 Academic Sandbox Notice:</strong> This is a student simulation workspace. Do not enter actual corporate credentials or active personal passwords.
      </div>

      <h1>Sign In</h1>
      <p style="color: var(--secondary); margin-top: -1rem; margin-bottom: 2rem; font-size: 0.875rem;">
        Access your administrative sandbox billing environment.
      </p>

      <% if(typeof err !== 'undefined' && err) { %>
        <div class="error-msg" style="margin-bottom: 1.5rem;">
          <%= err %>
        </div>
      <% } %>

      <form action="/auth/sign-in" method="POST">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required autofocus placeholder="e.g., admin_demo">
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required placeholder="e.g., password123">
        </div>

        <div class="form-actions" style="margin-top: 2rem;">
          <button type="submit" class="btn btn-primary btn-block">Authenticate Session</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/_footer.ejs') %>
  
</body>
</html>
