<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Sign In | PHARMABILL</title>
  </head>
  <body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="main-content">
      <div class="auth-card">
        <h1>Sign In</h1>
        <p style="color: var(--secondary); margin-top: -1rem; margin-bottom: 2rem; font-size: 0.875rem;">
          Access the secure pharmacy billing portal.
        </p>

        <% if(locals.err) { %>
          <div class="error-msg" style="margin-bottom: 1.5rem;">
            <%= err %>
          </div>
        <% } %>

        <form action="/auth/sign-in" method="POST">
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" required autofocus placeholder="Enter your username"/>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter your password"/>
          </div>

          <div class="form-actions" style="margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary btn-block">Sign In to Dashboard</button>
          </div>
        </form>
        
        <p style="margin-top: 2rem; font-size: 0.8125rem; color: var(--secondary);">
          New staff? Contact your administrator for system access.
        </p>
      </div>
    </div>
  </body>
</html>
