<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Staff Directory | Admin</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="main-content">
        <div class="detail-header">
            <div class="header-text">
                <h1>Staff Directory</h1>
                <p>Manage administrative roles and system access.</p>
            </div>
            <a href="/auth/sign-up" class="btn btn-primary">+ Register New Staff</a>
        </div>

        <div class="table-container">
            <table class="billing-table">
                <thead>
                    <tr>
                        <th class="text-left">Username</th>
                        <th>Role</th>
                        <th>Account Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td class="text-left">
                                <strong class="username-text"><%= u.username %></strong>
                                <% if(u._id.toString() === user._id.toString()) { %>
                                    <span class="badge badge-self current-user-badge">YOU</span>
                                <% } %>
                            </td>
                            <td>
                                <span class="badge <%= u.role === 'admin' ? 'status-paid' : 'status-pending' %>">
                                    <%= u.role.toUpperCase() %>
                                </span>
                            </td>
                            <td class="date-text">
                                <%= new Date(u.createdAt).toLocaleDateString() %>
                            </td>
                            <td>
                                <% if(u._id.toString() !== user._id.toString()) { %>
                                    <div class="action-group">
                                        <form action="/user/<%= u._id %>/role?_method=PUT" method="POST" class="role-form">
                                            <select name="role" class="role-select">
                                                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                                                <option value="admin"<%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                            </select>
                                            <button type="submit" class="btn btn-outline btn-small">Save</button>
                                        </form>
                                        <form action="/user/<%= u._id %>?_method=DELETE" method="POST" class="delete-form">
                                            <button type="submit" class="btn btn-outline btn-small btn-delete" onClick="return confirm('PERMANENTLY remove this staff member?')">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                <% } else { %>
                                    <a href="/user/profile" class="settings-link">My Settings</a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
