<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Staff Directory | PHARMABILL</title>
</head>
<body>
    <%- include('../partials/_navbar.ejs') %>

    <div class="main-content">
        
        <% if (locals.deleteTarget) { %>
            <div class="error-msg" style="margin-bottom: 2rem; border-color: var(--warning); background: #fffbeb; color: #b45309; flex-direction: column; align-items: center; gap: 1rem; padding: 1.5rem;">
                <div style="text-align: center;">
                    <strong style="font-size: 1rem; display: block; margin-bottom: 0.25rem;">⚠️ Safety Verification Required</strong>
                    <p style="margin: 0; font-size: 0.875rem;">Are you absolutely sure you want to permanently remove <strong><%= deleteTarget.username %></strong> from system access?</p>
                </div>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; width: 100%; max-width: 320px; margin: 0 auto; box-sizing: border-box;">
                    <form action="/user/<%= deleteTarget._id %>?_method=DELETE" method="POST" style="margin: 0; width: 100%; padding: 0;">
                        <button type="submit" class="btn btn-danger btn-block" style="height: 38px; padding: 0; margin: 0; width: 100%;">Yes, Delete</button>
                    </form>
                    <button type="button" class="btn btn-outline btn-block" onclick="window.location.href='/user'" style="height: 38px; padding: 0; margin: 0; width: 100%;">Cancel</button>
                </div>
            </div>
        <% } %>

        <div class="wide-wrapper" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h1>Staff Directory</h1>
                <p style="color: var(--secondary); margin-top: 0.25rem; font-size: 0.875rem;">
                    Manage administrative roles and system access.
                </p>
            </div>
            <div>
                <a href="/auth/sign-up" class="btn btn-primary">+ Register New Staff</a>
            </div>
        </div>

        <div class="wide-wrapper">
            <table class="billing-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Account Created</th>
                        <th style="text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td>
                                <strong class="username-text" style="color: var(--text-dark);"><%= u.username %></strong>
                                <% if(u._id.toString() === user._id.toString()) { %>
                                    <span class="badge badge-self" style="margin-left: 5px;">YOU</span>
                                <% } %>
                            </td>
                            <td>
                                <span class="badge <%= u.role === 'admin' ? 'status-paid' : 'status-pending' %>">
                                    <%= u.role.toUpperCase() %>
                                </span>
                            </td>
                            <td style="color: var(--secondary); font-size: 0.875rem;">
                                <%= new Date(u.createdAt).toLocaleDateString() %>
                            </td>
                            <td>
                                <% if(u._id.toString() !== user._id.toString()) { %>
                                    <div style="display: flex; gap: 8px; align-items: center; justify-content: center;">
                                      <form action="/user/<%= u._id %>/role?_method=PUT" method="POST" style="display: flex; align-items: center; gap: 6px; margin: 0;">
                                        <select name="role" style="height: 32px; padding: 0 0.5rem; width: 95px; font-size: 0.8rem; margin: 0;">
                                          <option value="staff" <%= u.role === 'staff' ? 'selected' : '' %>>Staff</option>
                                          <option value="admin"<%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                        </select>
                                        <button type="submit" class="btn btn-outline" style="height: 32px; padding: 0 0.75rem; font-size: 0.75rem;">Save</button>
                                      </form>

                                      <a href="/user?confirmDelete=<%= u._id %>" class="btn btn-outline" style="height: 32px; padding: 0 0.75rem; font-size: 0.75rem; border-color: var(--danger); color: var(--danger); text-decoration: none; display: inline-flex; align-items: center;">
                                        Delete
                                      </a>
                                    </div>
                                <% } else { %>
                                    <div style="text-align: center;">
                                      <a href="/user/profile" style="font-size: 0.85rem; font-weight: 600; color: var(--primary); text-decoration: none;">My Settings</a>
                                    </div>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
